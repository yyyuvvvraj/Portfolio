# Use ONE provider at a time. Keep keys server-side only.

# Primary provider (recommended)
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL="gpt-4o-mini"

# Optional fallback provider
HUGGINGFACE_API_KEY="your_huggingface_api_key_here"
HUGGINGFACE_MODEL="moonshotai/Kimi-K2-Instruct:novita"
AI_PROVIDER="huggingface"

# Free no-card local option (recommended if you don't want any billing account)
# Requires Ollama running on your machine.
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_HOST="http://127.0.0.1:11434"
